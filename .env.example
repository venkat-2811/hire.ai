# ============================================
# FRONTEND ENVIRONMENT VARIABLES (VITE_* prefix)
# ============================================

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_URL=https://your-project.supabase.co

# Clerk Authentication (Frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key

# FastAPI backend (optional)
# If set, the frontend will prefer calling FastAPI at `${VITE_API_BASE_URL}/api/v2/*` for supported routes,
# and fall back to the existing Node/Vercel serverless APIs at `/api/*` when unavailable.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Dev-only: print structured API request diagnostics to console.
# Requires `DEV` mode + this flag set to 'true'.
VITE_API_DIAGNOSTICS=false

# ============================================
# SERVERLESS API ENVIRONMENT VARIABLES
# (Set these in Vercel Project Settings)
# ============================================

# Supabase (Server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Clerk Authentication (Server-side JWT verification)
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Resend Email Service
RESEND_API_KEY=re_LeTUho46_K2gU9mnXaxZGybaCEW9BTu6E
RESEND_FROM_EMAIL=onboarding@resend.dev

# Frontend URL (for email links)
FRONTEND_URL=https://hire-ai-sandy.vercel.app

# AssemblyAI (optional, for speech-to-text)
ASSEMBLYAI_API_KEY=your_assemblyai_key

# Stripe Payment Gateway
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
