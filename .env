# ============================================
# FRONTEND ENVIRONMENT VARIABLES (VITE_* prefix)
# ============================================

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_URL=https://your-project.supabase.co

# Clerk Authentication (Frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key

# ============================================
# SERVERLESS API ENVIRONMENT VARIABLES
# (Set these in Vercel Project Settings → Environment Variables)
# ============================================

# Supabase (Server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Clerk Authentication (Server-side JWT verification)
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev

# OpenAI Configuration
OPENAI_API_KEY="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"
# Resend Email Service
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Frontend URL (for email links — candidates click this to open assessments/interviews)
# Since Netlify is the primary domain, set this to hiretec.netlify.app
# Also update this same value in Vercel Project Settings → Environment Variables
