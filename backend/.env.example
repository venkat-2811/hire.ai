# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Application Configuration
UPLOAD_DIR=./uploads
VECTOR_STORE=faiss
VECTOR_STORE_PATH=./vector_store

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS Origins (comma-separated, include your Vercel frontend URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,https://your-app.vercel.app

# Frontend URL (used for links in emails)
FRONTEND_URL=http://localhost:8080
# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev

# Resend Email
RESEND_API_KEY=re_6CZkML1Z_JsqVbTWMVA8Y4z9B3dNZViTk
RESEND_FROM_EMAIL=onboarding@resend.dev

# AssemblyAI (Speech-to-text)
ASSEMBLYAI_API_KEY=your_assemblyai_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Logging
LOG_LEVEL=INFO

# Redis / Celery (foundation scaffolding)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
